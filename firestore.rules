rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public creation for bookings and enquiries for the website
    match /bookings/{bookingId} {
      allow create: if true;
    }
    match /enquiries/{enquiryId} {
      allow create: if true;
    }

    // For any other path, only allow reads and writes if the user is authenticated.
    // This single rule covers get, list, update, delete for all other collections.
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
