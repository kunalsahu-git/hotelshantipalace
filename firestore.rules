rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (exists(userPath)) {
        return get(userPath).data.role;
      }
      return null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    
    function isFrontDesk() {
      return isSignedIn() && getUserRole() == 'frontdesk';
    }

    function isHousekeeping() {
      return isSignedIn() && getUserRole() == 'housekeeping';
    }

    function isAdminOrFrontDesk() {
      let role = getUserRole();
      return isSignedIn() && (role == 'admin' || role == 'frontdesk');
    }

    function isAnyStaff() {
      let role = getUserRole();
      return isSignedIn() && (role == 'admin' || role == 'frontdesk' || role == 'housekeeping');
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // An authenticated user can create their own user document.
      allow create: if isOwner(userId);
      
      // Users can read their own profile. Any staff can read any profile.
      allow get, list: if isOwner(userId) || isAnyStaff();
      
      // Admins can update any user profile. Users can only update their own.
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    match /roomCategories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdminOrFrontDesk();
    }

    match /rooms/{roomId} {
      allow read: if isAnyStaff();
      allow create, update, delete: if isAdminOrFrontDesk();
      allow update: if isHousekeeping() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['housekeepingStatus']);
    }

    match /guests/{guestId} {
      allow read, write: if isAdminOrFrontDesk();
    }
    
    match /bookings/{bookingId} {
      // Public can create bookings from the website.
      // Admin/Frontdesk can read and write all bookings.
      allow create: if true; 
      allow read, update, delete: if isAdminOrFrontDesk();
    }
    
    match /bills/{billId} {
      allow read, write: if isAdminOrFrontDesk();
    }

    match /maintenanceTickets/{ticketId} {
      // Any staff can create tickets.
      // Admin/frontdesk can manage them.
      allow create: if isAnyStaff();
      allow read: if isAnyStaff();
      allow write: if isAdminOrFrontDesk();
    }
    
    match /enquiries/{enquiryId} {
      // Public can create enquiries from the website.
      // Admin/Frontdesk can read and write all enquiries.
      allow create: if true;
      allow read, write: if isAdminOrFrontDesk();
    }
    
    match /settings/{docId} {
       // Settings are public-read for the website.
       // Only admins can change them.
       allow get, list: if true;
       allow write: if isAdmin();
    }
  }
}
