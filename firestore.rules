rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    // Allow authenticated users to read and write any user document.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // --- Room Categories ---
    // Public read so guests can browse rooms. Write requires auth.
    match /roomCategories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Rooms ---
    // Allow authenticated users to read and write rooms.
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }

    // --- Guests ---
    // Allow website visitors to create a guest profile on booking.
    // The public QR check-in page (unauthenticated) can only update ID proof fields.
    // All other operations require auth.
    match /guests/{guestId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
      allow update: if request.auth != null
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['age', 'idType', 'idNumber', 'idFrontUrl', 'idBackUrl', 'idUploadedAt']);
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      // Allow anyone to create a booking (for the public website).
      allow create: if true;
      // Allow authenticated users to read (get + list) and modify bookings.
      allow read, delete: if request.auth != null;
      allow update: if request.auth != null
        // The QR check-in page may set guestId or additionalGuests on a booking.
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['guestId', 'additionalGuests']);
    }

    // --- Bills ---
    // Allow public get by ID (for shareable bill/invoice links).
    // List and write require authentication.
    match /bills/{billId} {
      allow get: if true;
      allow list, write: if request.auth != null;
    }

    // --- Maintenance Tickets ---
    // Allow authenticated users to read and write maintenance tickets.
    match /maintenanceTickets/{ticketId} {
      allow read, write: if request.auth != null;
    }

    // --- Enquiries ---
    match /enquiries/{enquiryId} {
      // Allow anyone to create an enquiry (for the public website).
      allow create: if true;
      // Allow authenticated users to read (get + list) and modify enquiries.
      allow read, update, delete: if request.auth != null;
    }

    // --- Settings ---
    // Allow public get (hotel name/address needed for public invoice pages).
    // List and write require authentication.
    match /settings/{docId} {
      allow get: if true;
      allow list, write: if request.auth != null;
    }
  }
}
