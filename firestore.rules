rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to safely get the user's role from their document.
    function getRole(userId) {
      // Use exists() to check if the user's document exists before trying to access its data.
      // This is crucial to prevent errors when a user is authenticated but their
      // user document hasn't been created yet (e.g., on first sign-up).
      if (exists(/databases/$(database)/documents/users/$(userId))) {
        return get(/databases/$(database)/documents/users/$(userId)).data.role;
      }
      return null; // Return null if the user document does not exist.
    }

    // Helper functions for roles
    function isStaff() {
      return request.auth != null && getRole(request.auth.uid) != null;
    }
    function isAdmin() {
      return isStaff() && getRole(request.auth.uid) == 'admin';
    }
    function isFrontDesk() {
      return isStaff() && (getRole(request.auth.uid) == 'admin' || getRole(request.auth.uid) == 'frontdesk');
    }
    function isHousekeeping() {
      return isStaff() && (getRole(request.auth.uid) == 'admin' || getRole(request.auth.uid) == 'housekeeping');
    }

    // --- User Profiles ---
    match /users/{userId} {
      // A user can create their own profile document. This is crucial for initial sign-up.
      allow create: if request.auth.uid == userId;
      // A user can read their own profile. An admin can read any profile.
      allow read: if request.auth.uid == userId || isAdmin();
      // A user can update their own profile. An admin can update any profile.
      allow update: if request.auth.uid == userId || isAdmin();
      // Only admins can list or delete users.
      allow list, delete: if isAdmin();
    }

    // --- Public Website Submissions ---
    match /enquiries/{enquiryId} {
      // Anyone can submit an enquiry form from the website.
      allow create: if true;
      // Frontdesk and admin can read, list, and update enquiries.
      allow read, list, update: if isFrontDesk();
      // Only admin can delete enquiries
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Anyone can create a booking from the website. Staff can create bookings from the admin panel.
      allow create: if true;
      // Frontdesk and admin can manage (read, list, update) bookings.
      allow read, list, update: if isFrontDesk();
      // Only admins can delete bookings.
      allow delete: if isAdmin();
    }

    // --- Hotel Management Collections (Staff Only) ---
    match /roomCategories/{categoryId} {
      // All staff can view room categories.
      allow read, list: if isStaff();
      // Only admin can create, update, or delete categories.
      allow write: if isAdmin();
    }

    match /rooms/{roomId} {
      // All staff can view room details.
      allow read, list: if isStaff();
      // Admin/Frontdesk can update room status. Housekeeping can update housekeeping status.
      allow update: if isFrontDesk() || isHousekeeping();
      // Only admin can create or delete rooms.
      allow create, delete: if isAdmin();
    }

    match /guests/{guestId} {
      // Frontdesk and admin can manage guests.
      allow read, list, write: if isFrontDesk();
    }

    match /bills/{billId} {
      // Frontdesk and admin can manage bills.
      allow read, list, write: if isFrontDesk();
    }

    match /maintenanceTickets/{ticketId} {
      // All staff can view tickets.
      allow read, list: if isStaff();
      // Any staff member can create a ticket.
      allow create: if isStaff();
      // Admin, frontdesk and housekeeping can update/resolve tickets.
      allow update: if isStaff();
      // Only admin can delete tickets.
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      // All staff can read settings.
      allow read, list: if isStaff();
      // Only admin can change settings.
      allow write: if isAdmin();
    }
  }
}
