rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly grant list, get, write to authenticated users for admin collections
    match /users/{userId} {
      allow get, list, write: if request.auth != null;
    }
    match /roomCategories/{categoryId} {
      allow get, list, write: if request.auth != null;
    }
    match /rooms/{roomId} {
      allow get, list, write: if request.auth != null;
    }
    match /guests/{guestId} {
      allow get, list, write: if request.auth != null;
    }
    match /bills/{billId} {
      allow get, list, write: if request.auth != null;
    }
    match /maintenanceTickets/{ticketId} {
      allow get, list, write: if request.auth != null;
    }
    match /settings/{docId} {
      allow get, list, write: if request.auth != null;
    }
    
    // Allow public creation for bookings, but restrict management to authenticated users.
    // Explicitly add 'list' to the authenticated rule.
    match /bookings/{bookingId} {
      allow create: if true;
      allow get, list, update, delete: if request.auth != null;
    }
    
    // Allow public creation for enquiries, but restrict management to authenticated users.
    // Explicitly add 'list' to the authenticated rule.
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow get, list, update, delete: if request.auth != null;
    }
  }
}
