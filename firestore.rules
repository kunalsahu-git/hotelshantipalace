rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for staff user profiles
    match /users/{userId} {
      // Allow a user to create their own profile document upon sign-up
      allow create: if request.auth.uid == userId;
      
      // Allow any signed-in staff member to read any user profile
      allow read: if isSignedIn();
      
      // For now, prevent updates and deletes until we implement role-based logic
      allow update, delete: if false;
    }

    // Rules for room categories - allow public read for the website
    match /roomCategories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn(); // Simplification: any staff can write for now
    }

    // Rules for individual rooms
    match /rooms/{roomId} {
      allow read, write: if isSignedIn(); // Simplification: any staff can read/write for now
    }
    
    // Rules for guest profiles
    match /guests/{guestId} {
      allow read, write: if isSignedIn(); // Simplification: any staff can read/write for now
    }
    
    // Rules for bookings
    match /bookings/{bookingId} {
      // Allow public to create new booking requests from the website
      allow create: if true;
      // Allow any signed-in staff member to read/update/delete bookings
      allow read, update, delete: if isSignedIn();
    }
    
    // Rules for bills
    match /bills/{billId} {
      allow read, write: if isSignedIn();
    }
    
    // Rules for maintenance tickets
    match /maintenanceTickets/{ticketId} {
      allow read, write: if isSignedIn();
    }
    
    // Rules for website enquiries
    match /enquiries/{enquiryId} {
       // Allow public to create new enquiries from the contact form
      allow create: if true;
      // Allow any signed-in staff member to read/update/delete enquiries
      allow read, update, delete: if isSignedIn();
    }
    
    // Rules for hotel-wide settings
    match /settings/{docId} {
       // Allow public read for website info (e.g., check-in times)
       allow read: if true;
       // Allow any signed-in staff member to write for now
       allow write: if isSignedIn();
    }
  }
}
