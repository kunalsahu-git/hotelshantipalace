rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (exists(userPath)) {
        return get(userPath).data.role;
      }
      return null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    
    function isFrontDesk() {
      return isSignedIn() && getUserRole() == 'frontdesk';
    }

    function isHousekeeping() {
      return isSignedIn() && getUserRole() == 'housekeeping';
    }

    function isAdminOrFrontDesk() {
      let role = getUserRole();
      return isSignedIn() && (role == 'admin' || role == 'frontdesk');
    }

    function isAnyStaff() {
      let role = getUserRole();
      return isSignedIn() && (role == 'admin' || role == 'frontdesk' || role == 'housekeeping');
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // A user can create their own document
      allow create: if isOwner(userId);
      // A user can read their own doc, any staff can read any other doc
      allow get: if isOwner(userId) || isAnyStaff(); 
      // Any staff can list users
      allow list: if isAnyStaff();
      // Only admins can modify/delete users
      allow update, delete: if isAdmin();
    }

    match /roomCategories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdminOrFrontDesk();
    }

    match /rooms/{roomId} {
      allow read: if isAnyStaff();
      allow create, delete: if isAdminOrFrontDesk();
      allow update: if (isHousekeeping() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['housekeepingStatus'])) || isAdminOrFrontDesk();
    }

    match /guests/{guestId} {
      allow read, write: if isAdminOrFrontDesk();
    }
    
    match /bookings/{bookingId} {
      // Public can create bookings from the website
      allow create: if true; 
      allow read, update, delete: if isAdminOrFrontDesk();
    }
    
    match /bills/{billId} {
      allow read, write: if isAdminOrFrontDesk();
    }

    match /maintenanceTickets/{ticketId} {
      allow create, read: if isAnyStaff();
      allow update, delete: if isAdminOrFrontDesk();
    }
    
    match /enquiries/{enquiryId} {
      // Public can create enquiries from the website
      allow create: if true;
      allow read, write: if isAdminOrFrontDesk();
    }
    
    match /settings/{docId} {
       // Settings are public-read for the website
       allow get, list: if true;
       allow write: if isAdmin();
    }
  }
}
