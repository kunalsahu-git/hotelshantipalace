rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to safely get the user's role from their document.
    function getRole(userId) {
      // Use exists() to check if the user's document exists before trying to access its data.
      // This is crucial to prevent errors when a user is authenticated but their
      // user document hasn't been created yet (e.g., on first sign-up).
      if (exists(/databases/$(database)/documents/users/$(userId))) {
        return get(/databases/$(database)/documents/users/$(userId)).data.role;
      }
      return null; // Return null if the user document does not exist.
    }

    // Helper functions for roles
    function isStaff() {
      return request.auth != null;
    }
    function isAdmin() {
      return isStaff() && getRole(request.auth.uid) == 'admin';
    }

    // --- User Profiles ---
    match /users/{userId} {
      // A user can create their own profile document. This is crucial for initial sign-up.
      allow create: if request.auth.uid == userId;
      // A user can read their own profile. An admin can read any profile.
      allow read: if request.auth.uid == userId || isAdmin();
      // A user can update their own profile. An admin can update any profile.
      allow update: if request.auth.uid == userId || isAdmin();
      // Only admins can list or delete users.
      allow list, delete: if isAdmin();
    }

    // --- Public Website Submissions ---
    match /enquiries/{enquiryId} {
      // Anyone can submit an enquiry form from the website.
      allow create: if true;
      // Admins can manage enquiries.
      allow read, list, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Anyone can create a booking from the website. Staff can create bookings from the admin panel.
      allow create: if true;
      // Admins can manage bookings.
      allow read, list, update, delete: if isAdmin();
    }

    // --- Hotel Management Collections (Admin Only) ---
    match /roomCategories/{categoryId} {
      // Admins can manage room categories.
      allow read, list, write: if isAdmin();
    }

    match /rooms/{roomId} {
      // Admins can manage rooms.
      allow read, list, write: if isAdmin();
    }

    match /guests/{guestId} {
      // Admins can manage guests.
      allow read, list, write: if isAdmin();
    }

    match /bills/{billId} {
      // Admins can manage bills.
      allow read, list, write: if isAdmin();
    }

    match /maintenanceTickets/{ticketId} {
       // Admins can manage maintenance tickets.
      allow read, list, write: if isAdmin();
    }

    match /settings/{docId} {
      // Admins can manage settings.
      allow read, list, write: if isAdmin();
    }
  }
}
