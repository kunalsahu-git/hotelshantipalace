rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isBooking(data) {
      return data.fullName is string && data.fullName.size() > 1 &&
             data.email is string && data.email.matches('.+@.+\..+') &&
             data.phone is string && data.phone.size() > 9 &&
             data.guests is number && data.guests > 0 &&
             data.roomTypeId is string &&
             data.roomTypeName is string &&
             data.checkIn is string && data.checkIn.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.checkOut is string && data.checkOut.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.numberOfNights is number && data.numberOfNights > 0 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status == 'reserved' &&
             data.bookingType == 'advance' &&
             data.source == 'website' &&
             data.specialRequests is string &&
             data.keys().hasOnly(['fullName', 'email', 'phone', 'guests', 'roomTypeId', 'roomTypeName', 'checkIn', 'checkOut', 'numberOfNights', 'totalPrice', 'status', 'bookingType', 'source', 'specialRequests']);
    }

    function isEnquiry(data) {
        return data.name is string && data.name.size() > 1 &&
               data.email is string && data.email.matches('.+@.+\..+') &&
               data.message is string && data.message.size() > 9 &&
               data.phone is string &&
               data.keys().hasOnly(['name', 'email', 'phone', 'message']);
    }

    match /bookings/{bookingId} {
      // Anyone can create a booking if the data is valid.
      // The `createdAt` field is handled by the server.
      allow create: if isBooking(request.resource.data);
      
      // No one can read, update, or delete bookings from the client-side.
      allow read, update, delete: if false;
    }

    match /enquiries/{enquiryId} {
        // Anyone can create an enquiry if the data is valid.
        // The `submittedAt` field is handled by the server.
        allow create: if isEnquiry(request.resource.data);
        
        // No one can read, update or delete.
        allow read, update, delete: if false;
    }
  }
}
