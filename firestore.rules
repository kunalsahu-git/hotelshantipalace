rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    // Allow authenticated users to read and write any user document.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // --- Room Categories ---
    // Allow authenticated users to read and write room categories.
    match /roomCategories/{categoryId} {
      allow read, write: if request.auth != null;
    }

    // --- Rooms ---
    // Allow authenticated users to read and write rooms.
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }

    // --- Guests ---
    // Allow authenticated users to read and write guest profiles.
    match /guests/{guestId} {
      allow read, write: if request.auth != null;
    }

    // --- Bookings ---
    // This block allows authenticated users to LIST the entire bookings collection.
    // This is required for the dashboard.
    match /bookings {
      allow list: if request.auth != null;
    }
    // This block handles operations on INDIVIDUAL booking documents.
    match /bookings/{bookingId} {
      // Allow anyone to create a booking (for the public website).
      allow create: if true;
      // Allow authenticated users to get, update, and delete specific bookings.
      allow get, update, delete: if request.auth != null;
    }

    // --- Bills ---
    // Allow authenticated users to read and write bills.
    match /bills/{billId} {
      allow read, write: if request.auth != null;
    }

    // --- Maintenance Tickets ---
    // Allow authenticated users to read and write maintenance tickets.
    match /maintenanceTickets/{ticketId} {
      allow read, write: if request.auth != null;
    }

    // --- Enquiries ---
    // This block allows authenticated users to LIST the entire enquiries collection.
    match /enquiries {
      allow list: if request.auth != null;
    }
    // This block handles operations on INDIVIDUAL enquiry documents.
    match /enquiries/{enquiryId} {
      // Allow anyone to create an enquiry (for the public website).
      allow create: if true;
      // Allow authenticated users to get, update, and delete specific enquiries.
      allow get, update, delete: if request.auth != null;
    }

    // --- Settings ---
    // Allow authenticated users to read and write hotel settings.
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
