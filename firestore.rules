rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    
    function isFrontDesk() {
      return isSignedIn() && getUserRole() == 'frontdesk';
    }

    function isHousekeeping() {
      return isSignedIn() && getUserRole() == 'housekeeping';
    }

    function isAdminOrFrontDesk() {
      let role = getUserRole();
      return isSignedIn() && (role == 'admin' || role == 'frontdesk');
    }

    function isAnyStaff() {
      let role = getUserRole();
      return isSignedIn() && (role == 'admin' || role == 'frontdesk' || role == 'housekeeping');
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    // /users/{uid}
    //   name, email, role (admin | frontdesk | housekeeping), 
    //   createdAt, isActive
    match /users/{userId} {
      allow read: if isAnyStaff();
      allow write: if isAdmin();
      allow get: if isOwner(userId);
    }

    // /roomCategories/{categoryId}
    //   name, description, basePrice, maxOccupancy, 
    //   amenities[], photoURL, isActive
    match /roomCategories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdminOrFrontDesk();
    }

    // /rooms/{roomId}
    //   roomNumber, floor, categoryId, categoryName,
    //   status (available | occupied | reserved | maintenance | dirty),
    //   housekeepingStatus (clean | dirty | in_progress | inspected),
    //   isActive, notes, currentBookingId
    match /rooms/{roomId} {
      allow read: if isAnyStaff();
      allow write: if isAdminOrFrontDesk();
      allow update: if isHousekeeping() && request.resource.data.keys().hasOnly(['housekeepingStatus']);
    }

    // /guests/{guestId}
    //   name, phone, email, idType, idNumber,
    //   address, nationality, notes, tags[],
    //   createdAt, totalStays, source (walkin | website)
    match /guests/{guestId} {
      allow read, write: if isAdminOrFrontDesk();
    }
    
    // /bookings/{bookingId}
    //   ...
    //   source (admin | website), 
    match /bookings/{bookingId} {
      allow create: if true; // Allow public creation for website bookings
      allow read, write: if isAdminOrFrontDesk();
    }
    
    // /bills/{billId}
    match /bills/{billId} {
      allow read, write: if isAdminOrFrontDesk();
    }

    // /maintenanceTickets/{ticketId}
    match /maintenanceTickets/{ticketId} {
      allow create: if isAnyStaff();
      allow read: if isAnyStaff();
      allow write: if isAdminOrFrontDesk();
    }
    
    // /enquiries/{enquiryId}
    match /enquiries/{enquiryId} {
      allow create: if true; // Allow public creation for website enquiries
      allow read, write: if isAdminOrFrontDesk();
    }
    
    // /settings/{doc}
    match /settings/{docId} {
       allow get, list: if true;
       allow write: if isAdmin();
    }
  }
}
