rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Admin Panel Collections ---
    // Authenticated admins can read and write to these collections.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /roomCategories/{categoryId} {
      allow read, write: if request.auth != null;
    }
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }
    match /guests/{guestId} {
      allow read, write: if request.auth != null;
    }
    match /bills/{billId} {
      allow read, write: if request.auth != null;
    }
    match /maintenanceTickets/{ticketId} {
      allow read, write: if request.auth != null;
    }
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // --- Collections with Public Write Access ---

    // Bookings:
    // 'read' covers 'get' and 'list'. 'write' covers 'create', 'update', 'delete'.
    // We need to allow public 'create' but restrict other operations.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Enquiries:
    // Allow anyone to create, but only authenticated users to manage.
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
