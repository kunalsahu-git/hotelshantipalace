rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safely get the user's role from their document
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Check if the user is an admin
    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }
    
    // Check if the user is a front desk staff (or an admin, who can do everything)
    function isFrontdesk() {
        return isSignedIn() && (getRole() == 'frontdesk' || isAdmin());
    }

    // --- Rules for each collection ---

    // USERS: Admin can manage, users can create/read their own profile.
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if isAdmin();
    }
    
    // ROOM CATEGORIES: Public can read, admin/frontdesk can write
    match /roomCategories/{categoryId} {
        allow read: if true;
        allow write: if isFrontdesk();
    }

    // ROOMS: admin/frontdesk can write, housekeeping can read & update status
    match /rooms/{roomId} {
        allow read: if isSignedIn(); // All staff can see rooms
        allow write: if isFrontdesk();
        // Housekeeping can only update the housekeeping status
        allow update: if getRole() == 'housekeeping' && request.resource.data.keys().hasOnly(['housekeepingStatus']);
    }

    // GUESTS: Admin/frontdesk can manage
    match /guests/{guestId} {
        allow read, write: if isFrontdesk();
    }

    // BOOKINGS: Public can create, admin/frontdesk can manage.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isFrontdesk();
    }

    // BILLS: Admin/frontdesk can manage.
    match /bills/{billId} {
      allow read, write: if isFrontdesk();
    }

    // MAINTENANCE: All staff can create/read, admin/frontdesk can update.
    match /maintenanceTickets/{ticketId} {
        allow create, read: if isSignedIn();
        allow update, delete: if isFrontdesk();
    }

    // ENQUIRIES: Public can create, admin/frontdesk can manage.
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if isFrontdesk();
    }

    // SETTINGS: Public can read, admin can write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
