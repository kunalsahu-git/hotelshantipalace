rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // By default, allow all reads and writes if the user is authenticated.
    // This provides a secure default for the admin panel while we build.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // --- Public Website Submissions ---
    // Anyone (even unauthenticated users) can submit an enquiry form from the website.
    match /enquiries/{enquiryId} {
      allow create: if true;
    }

    // Anyone (even unauthenticated users) can create a booking request from the website.
    match /bookings/{bookingId} {
      allow create: if true;
    }
  }
}
