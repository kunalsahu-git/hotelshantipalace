rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{bookingId} {
      // Allow creation of bookings if the essential fields are present.
      // In a real app, you'd have more robust validation.
      allow create: if request.resource.data.fullName is string
                      && request.resource.data.email is string
                      && request.resource.data.status == 'reserved';

      // This is insecure for a production app, but allows viewing data.
      // In a real app, you should restrict this to authenticated admin users.
      allow read: if true;
      
      // Disallow updates and deletes from the client for now.
      allow update, delete: if false;
    }

    match /enquiries/{enquiryId} {
        // Allow creation of enquiries if the essential fields are present.
        allow create: if request.resource.data.name is string 
                        && request.resource.data.email is string 
                        && request.resource.data.message is string;
        
        // This is insecure for a production app.
        allow read: if true;
        allow update, delete: if false;
    }
  }
}
